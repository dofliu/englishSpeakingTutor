rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, preferredAccent, totalSessions, lastActive
    //
    // Collection: users/{userId}/sessions
    // Fields: userId, accent, topic, duration, timestamp, feedback
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('preferredAccent' in data) || data.preferredAccent in ['US', 'UK', 'AU', 'IN']) &&
             (!('totalSessions' in data) || data.totalSessions is number);
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'accent', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.accent is string &&
             data.timestamp is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSession(request.resource.data);
    }
  }
}
